  m_Name: SpaceProgramCEOWhileRobotGettingToRocket
  m_EditorClassIdentifier: 
  canHaveAgain: 0
  dialogLines:
  - eventToRaiseBefore: {fileID: 0}
    hideSpacebarPrompt: 1
    talkerName: CEO
    words: Who are you?
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    hideSpacebarPrompt: 1
    talkerName: CEO
    words: Why are you doing this?
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    hideSpacebarPrompt: 1
    talkerName: CEO
    words: "You can\u2019t do this, you don\u2019t understand!"
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    hideSpacebarPrompt: 1
    talkerName: CEO
    words: 'If you steal the rocket, we are doomed! '
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    hideSpacebarPrompt: 1
    talkerName: CEO
    words: An asteroid is bound for our planet within the hour, and we need that
      rocket to change its trajectory!
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    hideSpacebarPrompt: 1
    talkerName: CEO
    words: Listen to me please! You are not only a robot, think for yourself for
      once!
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    hideSpacebarPrompt: 1
    talkerName: CEO
    words: "Don\u2019t take the rocket, have mercyyyy\u2026 "
    eventToRaiseAfter: {fileID: 0}
