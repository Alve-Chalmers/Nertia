  m_Script: {fileID: 11500000, guid: 94c7008ec2153b94991d631668abaf4e, type: 3}
  m_Name: Hermit1
  m_EditorClassIdentifier: 
  canHaveAgain: 0
  dialogLines:
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Hermit
    words: Ey? What are you supposed to be? Get out of here!
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Robot
    words: Robot.
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Hermit
    words: "And what is that supposed to mean? Whatever, it doesn\u2019t matter"
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Hermit
    words: Why are you here?
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Robot
    words: Crash.
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Hermit
    words: Alright why do I care, what do you want?
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Robot
    words: Get
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Robot
    words: Home
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Hermit
    words: 'Ohh then you may be in luck! This moron CEO of the Space Program is building
      a Rocket as we speak

'
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Hermit
    words: "That would be great\u2026 For you to sweep the rug under him at the last
      minute, right before he becomes the great hero of this world\u2026"
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Robot
    words: Why
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Robot
    words: You
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Robot
    words: Hate
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Robot
    words: Him
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Hermit
    words: He is the reason I'm living here all alone! Once I was the boxing champion
      of the world, until my fight with him.
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Hermit
    words: "He was dirty, ugly and most of all very lucky\u2026"
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Hermit
    words: "Don\u2019t mind my old wounds, what matters now is you giving me my revenge!"
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 11400000, guid: 6ade3c4380b32064d88e1a1746c9d435, type: 2}
    talkerName: Hermit
    words: " I have this old boxing glove you can use to get out of this hellish
      cave and travel towards the Space Program, I don\u2019t need them anymore. "
    eventToRaiseAfter: {fileID: 0}
  - eventToRaiseBefore: {fileID: 0}
    talkerName: Hermit
    words: Good luck and remember to avenge me!
    eventToRaiseAfter: {fileID: 0}
